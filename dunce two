/* ── DISCOVERY VS LOYALTY ── */
function buildLoyaltyData(){
  const seen={};const years=['2021','2022','2023','2024','2025','2026'];
  years.forEach(yr=>{(YEARLY_TRACKS[yr]||[]).forEach(t=>{const k=t.track+'||'+t.artist;if(!seen[k])seen[k]={track:t.track,artist:t.artist,years:new Set(),totalMins:0,totalPlays:0};seen[k].years.add(yr);seen[k].totalMins+=t.mins;seen[k].totalPlays+=t.plays;});});
  return Object.values(seen).map(d=>({...d,span:d.years.size}));
}
let loyaltyInited=false;
function initLoyalty(){
  if(loyaltyInited)return;loyaltyInited=true;
  const data=buildLoyaltyData();
  const maxPlays=Math.max(...data.map(d=>d.totalPlays));
  const maxMins=Math.max(...data.map(d=>d.totalMins));
  const wrap=document.getElementById('loyaltyScatter');
  const tip=document.getElementById('loyaltyTip');
  const W=wrap.offsetWidth||600,H=360,PAD={l:70,r:20,t:20,b:40};
  const plotW=W-PAD.l-PAD.r,plotH=H-PAD.t-PAD.b;
  data.forEach(d=>{
    const x=PAD.l+(d.totalPlays/maxPlays)*plotW;
    const y=PAD.t+plotH-((d.span-1)/4)*plotH;
    const r=Math.max(5,Math.round((d.totalMins/maxMins)*22));
    const loyal=d.span>=3;
    const dot=document.createElement('div');dot.className='loyalty-dot';
    dot.style.cssText=`left:${x-r}px;top:${y-r}px;width:${r*2}px;height:${r*2}px;background:${loyal?'rgba(200,245,90,0.55)':'rgba(123,108,245,0.45)'};border:1px solid ${loyal?'#c8f55a':'#7b6cf5'}`;
    dot.addEventListener('mouseenter',()=>{tip.style.display='block';tip.innerHTML=`<strong>${d.track}</strong>${d.artist}<br>${d.span} year${d.span>1?'s':''} · ${d.totalPlays} plays · ${d.totalMins.toFixed(0)}m`;});
    dot.addEventListener('mousemove',e=>{const bx=wrap.getBoundingClientRect();let tx=e.clientX-bx.left+12,ty=e.clientY-bx.top-10;if(tx+180>W)tx-=200;tip.style.left=tx+'px';tip.style.top=ty+'px';});
    dot.addEventListener('mouseleave',()=>tip.style.display='none');
    wrap.appendChild(dot);
  });
  [1,2,3,4,5].forEach(n=>{const lbl=document.createElement('div');lbl.style.cssText=`position:absolute;left:${PAD.l-32}px;top:${PAD.t+plotH-((n-1)/4)*plotH-8}px;font-size:.55rem;color:var(--muted)`;lbl.textContent=n+'yr';wrap.appendChild(lbl);});
  const loyal=data.filter(d=>d.span>=2).sort((a,b)=>b.span-a.span||b.totalPlays-a.totalPlays).slice(0,8);
  new Chart(document.getElementById('loyalTop').getContext('2d'),{type:'bar',data:{labels:loyal.map(d=>d.track.substring(0,20)+(d.track.length>20?'…':'')),datasets:[{data:loyal.map(d=>d.span),backgroundColor:'rgba(200,245,90,0.7)',borderRadius:3}]},options:{indexAxis:'y',responsive:true,plugins:{legend:{display:false},tooltip:{backgroundColor:'#111118',borderColor:'#2a2a38',borderWidth:1,callbacks:{label:c=>`${c.raw} years active`}}},scales:{x:{grid:{color:'#1e1e28'},ticks:{color:'#6b6b80',stepSize:1}},y:{grid:{display:false},ticks:{color:'#6b6b80',font:{family:'DM Mono',size:10}}}}}});
  const moments=data.filter(d=>d.span===1).sort((a,b)=>b.totalPlays-a.totalPlays).slice(0,8);
  new Chart(document.getElementById('momentTop').getContext('2d'),{type:'bar',data:{labels:moments.map(d=>d.track.substring(0,20)+(d.track.length>20?'…':'')),datasets:[{data:moments.map(d=>d.totalPlays),backgroundColor:'rgba(123,108,245,0.65)',borderRadius:3}]},options:{indexAxis:'y',responsive:true,plugins:{legend:{display:false},tooltip:{backgroundColor:'#111118',borderColor:'#2a2a38',borderWidth:1,callbacks:{label:c=>`${c.raw} plays in one year`}}},scales:{x:{grid:{color:'#1e1e28'},ticks:{color:'#6b6b80'}},y:{grid:{display:false},ticks:{color:'#6b6b80',font:{family:'DM Mono',size:10}}}}}});
}

/* ── SKIP PSYCHOLOGY ── */
let skipsInited=false;
function initSkips(){
  if(skipsInited)return;skipsInited=true;
  const withRate=TRACKS.filter(t=>t.plays>=50).map(t=>({...t,rate:Math.round((t.skips/t.plays)*100)}));
  const highSkip=[...withRate].sort((a,b)=>b.rate-a.rate).slice(0,10);
  const lowSkip=[...withRate].sort((a,b)=>a.rate-b.rate).slice(0,10);
  const hOpts={indexAxis:'y',responsive:true,plugins:{legend:{display:false},tooltip:{backgroundColor:'#111118',borderColor:'#2a2a38',borderWidth:1,callbacks:{label:c=>`${c.raw}% skipped`}}},scales:{x:{max:100,grid:{color:'#1e1e28'},ticks:{color:'#6b6b80',callback:v=>v+'%'}},y:{grid:{display:false},ticks:{color:'#6b6b80',font:{family:'DM Mono',size:10}}}}};
  new Chart(document.getElementById('skipHigh').getContext('2d'),{type:'bar',data:{labels:highSkip.map(t=>t.track.substring(0,18)+(t.track.length>18?'…':'')),datasets:[{data:highSkip.map(t=>t.rate),backgroundColor:highSkip.map(t=>`rgba(212,68,68,${0.3+t.rate/140})`),borderRadius:3}]},options:hOpts});
  new Chart(document.getElementById('skipLow').getContext('2d'),{type:'bar',data:{labels:lowSkip.map(t=>t.track.substring(0,18)+(t.track.length>18?'…':'')),datasets:[{data:lowSkip.map(t=>t.rate),backgroundColor:lowSkip.map(()=>'rgba(200,245,90,0.7)'),borderRadius:3}]},options:{...hOpts,scales:{x:{max:100,grid:{color:'#1e1e28'},ticks:{color:'#6b6b80',callback:v=>v+'%'}},y:{grid:{display:false},ticks:{color:'#6b6b80',font:{family:'DM Mono',size:10}}}}}});
  const artistSkip={};
  TRACKS.forEach(t=>{if(!artistSkip[t.artist])artistSkip[t.artist]={skips:0,plays:0,count:0};artistSkip[t.artist].skips+=t.skips;artistSkip[t.artist].plays+=t.plays;artistSkip[t.artist].count++;});
  const artistRates=Object.entries(artistSkip).filter(([,v])=>v.count>=2&&v.plays>=80).map(([a,v])=>({artist:a,rate:Math.round((v.skips/v.plays)*100)})).sort((a,b)=>a.rate-b.rate);
  new Chart(document.getElementById('skipArtist').getContext('2d'),{type:'bar',data:{labels:artistRates.map(a=>a.artist),datasets:[{data:artistRates.map(a=>a.rate),backgroundColor:artistRates.map(a=>a.rate<15?'rgba(200,245,90,0.7)':a.rate<30?'rgba(245,200,74,0.7)':'rgba(212,68,68,0.65)'),borderRadius:3}]},options:{responsive:true,plugins:{legend:{display:false},tooltip:{backgroundColor:'#111118',borderColor:'#2a2a38',borderWidth:1,callbacks:{label:c=>`${c.raw}% avg skip rate`}}},scales:{x:{grid:{color:'#1e1e28'},ticks:{color:'#6b6b80',font:{family:'DM Mono',size:10},maxRotation:35}},y:{grid:{color:'#1e1e28'},ticks:{color:'#6b6b80',callback:v=>v+'%'}}}}});
}
