    <div class="year-stat"><div class="v">${YEAR_TOTALS[yr]}h</div><div class="l">Listening</div></div>
    <div class="year-stat"><div class="v">${(YEAR_STREAMS[yr]||0).toLocaleString()}</div><div class="l">Streams</div></div>
    <div class="year-stat"><div class="v" style="font-size:1rem">${tracks[0]?tracks[0].artist:'—'}</div><div class="l">Top artist</div></div>
    <div class="year-stat"><div class="v" style="font-size:.85rem">${tracks[0]?tracks[0].track.substring(0,22):'—'}</div><div class="l">Top track</div></div>
  </div>
  <div class="year-grid">
    <div class="chart-card"><div class="chart-title">Top tracks of ${yr}</div><div class="mini-track-list">${trackRows}</div></div>
    <div class="chart-card"><div class="chart-title">Top albums of ${yr}</div><div class="mini-track-list">${albumRows}</div></div>
  </div>`;
}

let currentSort='mins',currentPage=1;const PER_PAGE=15;let filteredTracks=[...TRACKS];
function sortTracks(key){currentSort=key;currentPage=1;document.querySelectorAll('.sort-btn').forEach(b=>b.classList.remove('active'));const map={mins:'sortTime',plays:'sortPlays',skips:'sortSkips',rate:'sortRate'};if(map[key])document.getElementById(map[key]).classList.add('active');filterTracks();}
function filterTracks(){const q=document.getElementById('trackSearch').value.toLowerCase();filteredTracks=TRACKS.filter(t=>t.track.toLowerCase().includes(q)||t.artist.toLowerCase().includes(q));if(currentSort==='rate')filteredTracks.sort((a,b)=>(b.skips/b.plays)-(a.skips/a.plays));else filteredTracks.sort((a,b)=>b[currentSort]-a[currentSort]);currentPage=1;renderTracks();}
function renderTracks(){
  const maxMins=Math.max(...filteredTracks.map(t=>t.mins));const start=(currentPage-1)*PER_PAGE;const page=filteredTracks.slice(start,start+PER_PAGE);
  document.getElementById('trackBody').innerHTML=page.map((t,i)=>{
    const rank=start+i+1;const bc=rank===1?'gold':rank===2?'silver':rank===3?'bronze':'';
    const barW=Math.round((t.mins/maxMins)*120);const sp=t.plays>0?Math.round((t.skips/t.plays)*100):0;
    const isNew=rank===1&&t.track==='Baby Girl';
    return`<tr><td><span class="rank-badge ${bc}">${rank}</span></td><td><div class="track-name">${t.track}${isNew?'<span class="new-badge">All-time #1</span>':''}</div><div class="track-artist">${t.artist} · ${t.album}</div></td><td>${t.mins.toFixed(0)} min</td><td>${t.plays}</td><td>${t.skips} <span style="font-size:.65rem;color:var(--muted)">(${sp}%)</span></td><td><div class="bar-cell"><div class="mini-bar" style="width:${barW}px"></div><span style="font-size:.65rem;color:var(--muted)">${100-sp}% complete</span></div></td></tr>`;
  }).join('');
  const totalPages=Math.ceil(filteredTracks.length/PER_PAGE);let html=`<span>${filteredTracks.length} tracks</span>`;
  for(let p=1;p<=totalPages;p++)html+=`<button class="page-btn ${p===currentPage?'active':''}" onclick="goPage(${p})">${p}</button>`;
  document.getElementById('pagination').innerHTML=html;
}
function goPage(p){currentPage=p;renderTracks();}

function initAlbums(){const grid=document.getElementById('albumGrid');if(grid.children.length)return;grid.innerHTML=ALBUMS.map((a,i)=>`<div class="album-card"><div class="album-name">${a.album}</div><div class="album-artist">${a.artist}</div><div class="album-stats">${a.hrs}h · ${a.plays.toLocaleString()} plays</div><div class="album-rank-bg">${i+1}</div></div>`).join('');}

function initArtists(){const list=document.getElementById('artistList');if(list.children.length)return;const m=ARTISTS[0].hrs;list.innerHTML=ARTISTS.map((a,i)=>`<div class="artist-row"><div class="artist-rank">${i+1}</div><div class="artist-name">${a.artist}</div><div class="artist-bar-wrap"><div class="artist-bar" style="width:${Math.round((a.hrs/m)*100)}%"></div><div class="artist-stats">${a.hrs}h · ${a.plays.toLocaleString()} plays</div></div></div>`).join('');}

let erasInited=false;
function initEras(){if(erasInited)return;erasInited=true;
  document.getElementById('eraGrid').innerHTML=Object.entries(YEARLY_TOP).map(([yr,top])=>{const y=YEARLY.find(x=>x.year===yr)||{hrs:0};return`<div class="era-card"><div class="era-hrs">${y.hrs}h</div>${top.map(a=>`<div class="era-artist-line"><strong>${a.artist}</strong> · ${a.hrs}h</div>`).join('')}<div class="era-year-bg">${yr}</div></div>`;}).join('');
  new Chart(document.getElementById('yearChart').getContext('2d'),{type:'bar',data:{labels:YEARLY.map(y=>y.year),datasets:[{data:YEARLY.map(y=>y.hrs),backgroundColor:YEARLY.map(y=>y.hrs>500?'rgba(200,245,90,0.85)':'rgba(123,108,245,0.55)'),borderRadius:3,borderSkipped:false}]},options:{responsive:true,plugins:{legend:{display:false},tooltip:{backgroundColor:'#111118',borderColor:'#2a2a38',borderWidth:1,titleColor:'#c8f55a',bodyColor:'#e8e8f0',callbacks:{label:c=>`${c.raw.toFixed(0)} hours`}}},scales:{x:{grid:{color:'#1e1e28'},ticks:{color:'#6b6b80',font:{family:'DM Mono',size:11}}},y:{grid:{color:'#1e1e28'},ticks:{color:'#6b6b80',font:{family:'DM Mono',size:11},callback:v=>v+'h'}}}}});}

let timelineInited=false;
function initTimeline(){if(timelineInited)return;timelineInited=true;new Chart(document.getElementById('timelineChart').getContext('2d'),{type:'bar',data:{labels:MONTHLY.map(m=>m.month),datasets:[{data:MONTHLY.map(m=>m.hrs),backgroundColor:MONTHLY.map(m=>m.hrs>100?'rgba(200,245,90,0.85)':m.hrs>50?'rgba(200,245,90,0.55)':'rgba(123,108,245,0.6)'),borderRadius:2,borderSkipped:false}]},options:{responsive:true,plugins:{legend:{display:false},tooltip:{backgroundColor:'#111118',borderColor:'#2a2a38',borderWidth:1,titleColor:'#c8f55a',bodyColor:'#e8e8f0',callbacks:{label:c=>`${c.raw.toFixed(1)} hours`}}},scales:{x:{grid:{color:'#1e1e28'},ticks:{color:'#6b6b80',font:{family:'DM Mono',size:9},maxRotation:45}},y:{grid:{color:'#1e1e28'},ticks:{color:'#6b6b80',font:{family:'DM Mono',size:11},callback:v=>v+'h'}}}}});}

let patternsInited=false;
function initPatterns(){if(patternsInited)return;patternsInited=true;
  const maxH=Math.max(...HOURLY.map(h=>h.hrs));
  document.getElementById('heatmap').innerHTML=HOURLY.map(h=>{const pct=h.hrs/maxH,height=Math.max(4,Math.round(pct*100));const r=Math.round(123+(200-123)*pct),g=Math.round(108+(245-108)*pct),b=Math.round(245+(90-245)*pct);const lbl=h.hour===0?'12a':h.hour<12?h.hour+'a':h.hour===12?'12p':(h.hour-12)+'p';return`<div class="hour-col"><div class="hour-bar-wrap"><div class="hour-bar" style="height:${height}%;background:rgb(${r},${g},${b})" title="${h.hour}:00 — ${h.hrs.toFixed(1)}h"></div></div><div class="hour-label">${lbl}</div></div>`;}).join('');
  new Chart(document.getElementById('scatterChart').getContext('2d'),{type:'scatter',data:{datasets:[{data:TRACKS.slice(0,10).map(t=>({x:t.plays,y:t.mins,label:t.track})),backgroundColor:'rgba(200,245,90,0.7)',pointRadius:8,pointHoverRadius:10}]},options:{responsive:true,plugins:{legend:{display:false},tooltip:{backgroundColor:'#111118',borderColor:'#2a2a38',borderWidth:1,callbacks:{label:c=>[c.raw.label,`${c.raw.x} plays · ${c.raw.y.toFixed(0)} mins`]}}},scales:{x:{title:{display:true,text:'Plays',color:'#6b6b80',font:{family:'DM Mono',size:10}},grid:{color:'#1e1e28'},ticks:{color:'#6b6b80'}},y:{title:{display:true,text:'Minutes',color:'#6b6b80',font:{family:'DM Mono',size:10}},grid:{color:'#1e1e28'},ticks:{color:'#6b6b80'}}}}});
  const devoted=TRACKS.filter(t=>t.plays>=50).map(t=>({...t,rate:Math.round((t.skips/t.plays)*100)})).sort((a,b)=>a.rate-b.rate).slice(0,8);
  new Chart(document.getElementById('devotionChart').getContext('2d'),{type:'bar',data:{labels:devoted.map(t=>t.track.substring(0,18)+(t.track.length>18?'…':'')),datasets:[{data:devoted.map(t=>t.rate),backgroundColor:devoted.map(t=>t.rate<10?'rgba(200,245,90,0.8)':'rgba(123,108,245,0.6)'),borderRadius:3}]},options:{indexAxis:'y',responsive:true,plugins:{legend:{display:false},tooltip:{backgroundColor:'#111118',borderColor:'#2a2a38',borderWidth:1,callbacks:{label:c=>`${c.raw}% skipped`}}},scales:{x:{grid:{color:'#1e1e28'},ticks:{color:'#6b6b80',callback:v=>v+'%'}},y:{grid:{display:false},ticks:{color:'#6b6b80',font:{family:'DM Mono',size:10}}}}}});}

renderTracks();

/* ── GENRE CLUSTERS ── */
