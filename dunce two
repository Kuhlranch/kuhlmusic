  {name:'Dark Indie / Post-Punk',hrs:207.1,color:'#7b6cf5',artists:'Johnny Goth, Daughter, Provoker, IAMX, Mr.Kitty, Kerli'},
  {name:'Psychedelic / Art Rock',hrs:115.3,color:'#c8f55a',artists:'Pink Floyd, Tame Impala, Muse, Mk.gee'},
  {name:'Electronic / Hypnagogic',hrs:134.9,color:'#f5c84a',artists:'Jai Paul, Alexander Spit, Com Truise, Mareux, BAYNK'},
