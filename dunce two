const builtYears={};
function buildYearPanel(yr){
  if(builtYears[yr])return;builtYears[yr]=true;
  const el=document.getElementById('year-'+yr);
  const tracks=YEARLY_TRACKS[yr]||[];const albums=YEARLY_ALBUMS[yr]||[];
